{
  "permissions": {
    "allow": [
      "Bash(uv run pytest*)",
      "Bash(uv sync*)",
      "Bash(uv run black*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -q '\\.py$' && uv run black . 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
